[Script]
http-request ^https:\/\/8\.95508\.com\/creditbank\/mgs\/mgw\.htm$ script-path=https://raw.githubusercontent.com/ZJ-zhangcn/loon-plugins/main/scripts/cgb-life-startup-ad-test.js, timeout=5, tag=发现精彩开屏配置拦截
http-response ^https:\/\/wap\.cgbchina\.com\.cn\/mdpNativeApi\/cawp\/h5-wealth-app\/noSessionServlet\/cawp\/base\/getPersonalizedRecommendations\.fun script-path=https://raw.githubusercontent.com/ZJ-zhangcn/loon-plugins/main/scripts/cgb-life-personalized-ad.js, requires-body=true, timeout=5, tag=发现精彩首页浮窗倒计时清理

[Rule]
URL-REGEX,^https:\/\/static\.95508\.com\/mmg\/ciop\/sysabbr\/cmep\/images\/popupads\/,REJECT
URL-REGEX,^https:\/\/static\.95508\.com\/icppweb\/images\/modelMaterial\/advertising\/,REJECT

[MITM]
hostname = 8.95508.com, static.95508.com, wap.cgbchina.com.cn
